{
  "name": "@vulos/mail-ui",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "description": "Shared React webmail UI for Vulos — talks to the lilmail /v1 JSON API.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.config.lib.js",
    "build:all": "npm run build && npm run build:lib",
    "preview": "vite preview",
    "test": "vitest run",
    "screenshots": "node scripts/screenshots.mjs"
  },
  "main": "./dist-lib/index.cjs",
  "module": "./dist-lib/index.js",
  "types": "./dist-lib/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/lib/index.js",
      "import": "./dist-lib/index.js",
      "require": "./dist-lib/index.cjs",
      "default": "./dist-lib/index.js"
    },
    "./api": {
      "source": "./src/api.js",
      "import": "./dist-lib/api.js",
      "require": "./dist-lib/api.cjs",
      "default": "./dist-lib/api.js"
    },
    "./style.css": "./dist-lib/mail-ui.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist-lib/",
    "src/",
    "README.md"
  ],
  "dependencies": {
    "dompurify": "^3.4.5"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.3.5",
    "vitest": "^2.1.8"
  }
}
