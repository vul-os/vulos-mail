# Vulos Mail — local development config (load with VULOS_ENV=dev).
# Free user addresses are issued under this domain: <user>@vulos.to
VULOS_DOMAIN=vulos.to

# Self-signed TLS for local STARTTLS/HTTPS (no ACME in dev).
VULOS_TLS_SELFSIGNED=1

# High ports so no root is needed locally.
VULOS_MX_ADDR=127.0.0.1:2525
VULOS_SUBMIT_ADDR=127.0.0.1:2587
VULOS_IMAP_ADDR=127.0.0.1:2143
VULOS_JMAP_ADDR=127.0.0.1:2080
VULOS_METRICS_ADDR=127.0.0.1:2090

# Local data + a seeded demo account.
VULOS_DATA_DIR=./data
VULOS_ACCOUNT=alice@vulos.to
VULOS_PASSWORD=pw
